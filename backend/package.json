{
  "name": "backend",
  "version": "0.0.1",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "repl": "nest start --entryFile repl",
    "export:openapi": "ts-node -e \"require('./src/export-openapi')\" && echo 'openapi.json exported'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config jest.e2e.config.ts",
    "migration:run": "ts-node -r tsconfig-paths/register -e \"(async () => { const ds = require('./src/data-source').AppDataSource; let code = 0; try { await ds.initialize(); await ds.runMigrations(); console.log('Migrations complete'); } catch (e) { code = 1; console.error(e); } finally { if (ds.isInitialized) await ds.destroy(); process.exit(code); } })()\"",
    "migration:revert": "ts-node -r tsconfig-paths/register -e \"(async () => { const ds = require('./src/data-source').AppDataSource; let code = 0; try { await ds.initialize(); await ds.undoLastMigration(); console.log('Migration reverted'); } catch (e) { code = 1; console.error(e); } finally { if (ds.isInitialized) await ds.destroy(); process.exit(code); } })()\"",
    "migration:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate -d src/data-source.ts",
    "migration:create": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:create",
    "seed": "ts-node -r tsconfig-paths/register src/seeds/initial-seed.ts",
    "type-coverage": "npx type-coverage --at-least 95 --strict --ignore-files \"dist/**\" --ignore-files \"src/**/*.spec.ts\" --ignore-files \"src/**/*.e2e-spec.ts\" --ignore-files \"src/main.ts\" --ignore-files \"src/export-openapi.ts\" --ignore-files \"src/data-source.ts\" --ignore-files \"src/seeds/**\""
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.0.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/typeorm": "^11.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "mysql2": "^3.20.0",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "stripe": "^22.0.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.4.22",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "typescript-eslint": "^8.58.1"
  }
}
