  "info": {
    "title": "Todo API",
    "description": "NestJS + Swagger 学習用 Todo API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "UserProfileDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "address": {
            "type": "object",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "deletedAt": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "address",
          "createdAt",
          "deletedAt"
        ]
      },
      "ChangePasswordDto": {
        "type": "object",
        "properties": {
          "currentPassword": {
            "type": "string",
            "description": "現在のパスワード"
          },
          "newPassword": {
            "type": "string",
            "description": "新しいパスワード（8文字以上）"
          }
        },
        "required": [
          "currentPassword",
          "newPassword"
        ]
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "山田太郎",
            "description": "名前"
          },
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "メールアドレス"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "description": "8文字以上のパスワード"
          }
        },
        "required": [
          "name",
          "email",
          "password"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com",
            "description": "メールアドレス"
          },
          "password": {
            "type": "string",
            "example": "password123",
            "description": "8文字以上のパスワード"
          }
        },
        "required": [
          "email",
          "password"
        ]
      }
    }
  }
}