  "info": {
    "title": "Todo API",
    "description": "NestJS + Swagger 学習用 Todo API",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "UserProfileDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "address": {
            "type": "object",
            "nullable": true
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "deletedAt": {
            "type": "object",
            "nullable": true
          }
        },
        "required": [
          "id",
          "name",
          "email",
          "address",
          "createdAt",
          "deletedAt"
        ]
      },
      "UpdateUserProfileDto": {
        "type": "object",
        "properties": {
          "name": {
